# ---- Discord application (https://discord.com/developers/applications) ----
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-client-id
DISCORD_CLIENT_SECRET=your-application-client-secret
DISCORD_GUILD_ID=your-server-id

# Comma-separated role IDs that count as "admin" (can manage shift types/quotas, view roster)
ADMIN_ROLE_IDS=123456789012345678,234567890123456789

# Comma-separated role IDs allowed to manually add time on the website
# (people with an ADMIN_ROLE_IDS role can always add time too)
ADD_TIME_ROLE_IDS=345678901234567890

# ---- Website ----
# Must exactly match a redirect configured in the Discord Developer Portal
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
SESSION_SECRET=change-this-to-a-long-random-string
PORT=3000

# ---- Quota week ----
# Day the weekly quota resets on: 0=Sunday, 1=Monday, ... 6=Saturday
WEEK_START_DAY=1
